CREATE TABLE z00cp88.OB_freebie_all_sales AS

SELECT
    origination_channel,
    pm.promotion_id AS promotion_id,
    CASE 
        WHEN (origination_channel = 'STORE' AND transaction_id NOT IN ('-9999')) THEN transaction_id
        WHEN (origination_channel = 'ONLINE' AND customer_order_number NOT IN ('-9999')) THEN customer_order_number
    END AS transaction_id,
    CASE 
        WHEN origination_channel = 'STORE' THEN sale_d
        WHEN origination_channel = 'ONLINE' THEN order_d
    END AS sale_d,
    tcin,
    CASE
        WHEN (origination_channel = 'STORE') THEN 'Store'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('DIGITAL_DOWNLOAD','DIGITAL','SHIPTOHOME'))
            OR (origination_channel = 'ONLINE' AND reporting_channel IN ('DVS','FC') AND fulfillment_type IS NULL)
            THEN 'TargetCom Web'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('SHIPTOSTORE', 'STOREPICKUP', 'STORE POS','-N/A-')
            AND fulfillment_ship_option <> 'CURBSIDE')
            THEN 'Order Pickup'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('STOREPICKUP') AND fulfillment_ship_option = 'CURBSIDE')
            THEN 'DriveUp'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('MEMBERSHIP_SHIPT','SHIPT','SCHEDULEDDELIVERY_SHIPT','TIP_SHIPT'))
            THEN 'Shipt'
        ELSE 'Other'
    END AS ff_type,
    
  
    guest_information_struct.guest_profile_id,
    SUM(sale_q) AS sale_q,
    SUM(extended_net_a) AS promo_sale,
    SUM(-1 * pm.adjustment_amount) AS markdown

FROM prd_sls_fnd.sales_line_item
LATERAL VIEW explode(price_modifiers_arr) adj AS pm

WHERE transaction_type_c IN ('00', '01')
  AND class_type_c NOT IN ('04', '05', '12', '13', '14')
  AND origination_channel IN ('STORE','ONLINE')
  AND sale_d BETWEEN '2025-05-01' AND '2026-04-05'
  AND extended_net_a >= 0.00
  AND sale_q > 0.00
  AND guest_information_struct.guest_profile_id IS NOT NULL

GROUP BY
    origination_channel,
    pm.promotion_id,
    CASE 
        WHEN (origination_channel = 'STORE' AND transaction_id NOT IN ('-9999')) THEN transaction_id
        WHEN (origination_channel = 'ONLINE' AND customer_order_number NOT IN ('-9999')) THEN customer_order_number
    END,
    CASE 
        WHEN origination_channel = 'STORE' THEN sale_d
        WHEN origination_channel = 'ONLINE' THEN order_d
    END,
    CASE
        WHEN (origination_channel = 'STORE') THEN 'Store'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('DIGITAL_DOWNLOAD','DIGITAL','SHIPTOHOME'))
            OR (origination_channel = 'ONLINE' AND reporting_channel IN ('DVS','FC') AND fulfillment_type IS NULL)
            THEN 'TargetCom Web'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('SHIPTOSTORE', 'STOREPICKUP', 'STORE POS','-N/A-')
            AND fulfillment_ship_option <> 'CURBSIDE')
            THEN 'Order Pickup'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('STOREPICKUP') AND fulfillment_ship_option = 'CURBSIDE')
            THEN 'DriveUp'
        WHEN (origination_channel = 'ONLINE' AND fulfillment_type IN ('MEMBERSHIP_SHIPT','SHIPT','SCHEDULEDDELIVERY_SHIPT','TIP_SHIPT'))
            THEN 'Shipt'
        ELSE 'Other'
    END,
    tcin,
    guest_information_struct.guest_profile_id
;
